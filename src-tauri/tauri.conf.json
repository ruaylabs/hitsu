{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kagi",
  "version": "0.1.0",
  "identifier": "com.ruaylabs.kagi",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Kagi",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "backgroundColor": [239, 237, 229, 255]
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self'; img-src 'self' asset: https://asset.localhost data: blob:; connect-src 'self' ipc: https://tauri.localhost; media-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
